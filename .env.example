# Project NOVA - Environment Configuration
# Copy this file to .env and customize as needed

# ── NETWORK CONFIGURATION ──────────────────────────────────────
# MQTT Broker (FoxMQ) Configuration
FOXMQ_HOST=127.0.0.1
FOXMQ_PORT=1883

# WebSocket Server Port (for dashboard connection)
WS_PORT=8765

# ── SWARM CONFIGURATION ────────────────────────────────────────
# Number of drones in the swarm (default: 8)
NUM_DRONES=8

# ── FRONTEND CONFIGURATION ─────────────────────────────────────
# WebSocket port for frontend (should match WS_PORT above)
VITE_WS_PORT=8765

# ── USAGE INSTRUCTIONS ─────────────────────────────────────────
# 1. Copy this file: cp .env.example .env
# 2. Edit .env with your custom values
# 3. Restart the application

# ── EXAMPLES ───────────────────────────────────────────────────
# Run with 12 drones:
#   NUM_DRONES=12 python main.py
#
# Use different WebSocket port:
#   WS_PORT=9000 python main.py
#   VITE_WS_PORT=9000 npm run dev
#
# Connect to remote MQTT broker:
#   FOXMQ_HOST=192.168.1.100 python main.py
